# Variables de entorno para Vercel + TiDB Cloud
# Copiar a .env y rellenar con tus valores

# TiDB Cloud — Obtener desde la consola de TiDB Cloud > Connect > General
DATABASE_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
DATABASE_PORT=4000
DATABASE_USER=tu_usuario
DATABASE_PASSWORD=tu_contraseña
DATABASE_NAME=clinica_carlos_morillo

# JWT Secret — Usa un string largo y aleatorio
JWT_SECRET=cambia-esto-por-un-string-secreto-largo-y-aleatorio-1234567890
